{
  "root": true,
  "ignorePatterns": [
    "**/dist/**",
    "**/.next/**",
    "**/coverage/**",
    "**/node_modules/**"
  ],
  "overrides": [
    {
      "files": [
        "apps/api/src/**/*.ts"
      ],
      "parser": "@typescript-eslint/parser",
      "plugins": [
        "@typescript-eslint"
      ],
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended"
      ],
      "env": {
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
