{
  "name": "@almio/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:migrate:tenants": "ts-node prisma/migrate-tenants.ts",
    "prisma:migrate:release": "ts-node prisma/release-migrate.ts",
    "prisma:upsert-company-membership": "ts-node prisma/upsert-company-membership.ts",
    "prisma:provision-supabase-auth-user": "ts-node prisma/provision-supabase-auth-user.ts",
    "prisma:format": "prisma format",
    "prisma:promote-superadmin": "ts-node prisma/promote-superadmin.ts",
    "prisma:assign-branch-scopes": "ts-node prisma/assign-branch-scopes.ts",
    "prisma:login-and-test-branch-admin": "ts-node prisma/login-and-test-branch-admin.ts",
    "prisma:exercise-branch-admin-business-rules": "ts-node prisma/exercise-branch-admin-business-rules.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --runInBand --testRegex '.*\\.e2e-spec\\.ts$'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^5.9.6",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
