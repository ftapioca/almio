generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SaaSPlan {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  maxCompanies Int?    @map("max_companies")
  maxBranches Int      @map("max_branches")
  maxEmployees Int?   @map("max_employees")
  maxUsers    Int      @map("max_users")
  priceMonthly Decimal? @db.Decimal(12, 2) @map("price_monthly")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  subscriptions Subscription[]
  companies      Company[]

  @@map("saas_plans")
}

model Company {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  schemaName     String   @unique @map("schema_name")
  countryCode    String?  @map("country_code")
  currencyCode   String?  @map("currency_code")
  saasPlanId     String?  @map("saas_plan_id")
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  subscriptions Subscription[]
  memberships   CompanyMembership[]
  auditLogs     AuditLogSaaS[]
  saasPlan      SaaSPlan? @relation(fields: [saasPlanId], references: [id])
  country       Country?  @relation(fields: [countryCode], references: [code])
  currency      Currency? @relation(fields: [currencyCode], references: [code])

  @@map("companies")
}

model Subscription {
  id         String   @id @default(uuid())
  companyId   String   @map("company_id")
  saasPlanId  String   @map("saas_plan_id")
  status      String   @default("ACTIVE")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  company Company  @relation(fields: [companyId], references: [id])
  saasPlan SaaSPlan @relation(fields: [saasPlanId], references: [id])

  @@map("subscriptions")
}

model UserAccount {
  id              String   @id @default(uuid())
  supabaseUserId  String?  @unique @map("supabase_user_id")
  email           String   @unique
  fullName        String?  @map("full_name")
  status          String   @default("ACTIVE")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  memberships     CompanyMembership[]
  auditLogs       AuditLogSaaS[]

  @@map("user_accounts")
}

model CompanyMembership {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userAccountId String  @map("user_account_id")
  role         String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  company      Company     @relation(fields: [companyId], references: [id])
  userAccount  UserAccount @relation(fields: [userAccountId], references: [id])

  @@unique([companyId, userAccountId], map: "company_membership_unique")
  @@map("company_memberships")
}

model Country {
  code       String   @id
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  companies  Company[]

  @@map("countries")
}

model Currency {
  code       String   @id
  name       String
  symbol     String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  companies  Company[]

  @@map("currencies")
}

model AuditLogSaaS {
  id            String   @id @default(uuid())
  companyId      String?  @map("company_id")
  userAccountId  String?  @map("user_account_id")
  action         String
  resource       String
  detailsJson    Json?    @map("details_json")
  createdAt      DateTime @default(now()) @map("created_at")

  company        Company?     @relation(fields: [companyId], references: [id])
  userAccount    UserAccount? @relation(fields: [userAccountId], references: [id])

  @@map("audit_log_saas")
}
